ALICE_API_TOKEN=replace_me
# Runtime state root (db + memory + skills). Keep this outside the repo.
ALICE_STATE_DIR=/data/alice
# Optional override; default is ${ALICE_STATE_DIR}/db/alice.db
# ALICE_DATABASE_URL=sqlite+aiosqlite:////data/alice/db/alice.db
# Optional overrides; defaults are under ALICE_STATE_DIR
# ALICE_MEMORY_DIR=/data/alice/memory
# ALICE_SKILLS_DIR=/data/alice/skills
ALICE_CODEX_COMMAND=codex
ALICE_OPENAI_API_KEY=
ALICE_OPENAI_MODEL=gpt-5-mini
ALICE_CODEX_MODEL=
ALICE_FEISHU_APP_ID=
ALICE_FEISHU_APP_SECRET=
ALICE_FEISHU_BOT_TOKEN=
ALICE_FEISHU_SIGNING_SECRET=
ALICE_FEISHU_ENCRYPT_KEY=
ALICE_FEISHU_BASE_URL=https://open.feishu.cn
ALICE_APPROVAL_MODE=auto_all
ALICE_APPROVAL_REQUIRED_TOOLS=[]
ALICE_HTTP_WRITE_REQUIRES_APPROVAL=false
